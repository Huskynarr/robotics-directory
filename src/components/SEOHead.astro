---
import { CATEGORY_LABELS } from '../data/categories.js';
import { SITE_URL } from '../config/site.js';

interface Props {
  robot: Record<string, string>;
}

const { robot } = Astro.props;

const name = `${robot.manufacturer} ${robot.model}`;
const catLabel = CATEGORY_LABELS[robot.category] || robot.category;
const description = robot.description && robot.description.trim() && robot.description !== 'N/A'
  ? `${name} - ${catLabel}: ${robot.description}`
  : `${name} - ${catLabel} by ${robot.manufacturer}. View specs, images and compare with other robots.`;
const url = `${SITE_URL}/robot/${robot.id}/`;

const imageUrl = robot.image && robot.image !== 'images/image-not-found.webp'
  ? `${SITE_URL}/${robot.image.replace(/^\//, '')}`
  : undefined;

// Build JSON-LD
const jsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name,
  description,
  category: catLabel,
  brand: { '@type': 'Organization', name: robot.manufacturer },
  url,
};
if (imageUrl) jsonLd.image = imageUrl;
if (robot.website) jsonLd.sameAs = robot.website;

// Expose key specs as structured product properties
const SPEC_PROPS: Array<{ key: string; name: string }> = [
  { key: 'weight', name: 'Weight' },
  { key: 'size', name: 'Size' },
  { key: 'batteryLife', name: 'Battery life' },
  { key: 'maxRuntime', name: 'Max runtime' },
  { key: 'dof', name: 'Degrees of freedom' },
  { key: 'payload', name: 'Payload' },
  { key: 'speed', name: 'Max speed' },
  { key: 'ipRating', name: 'IP rating' },
  { key: 'terrain', name: 'Terrain' },
];
const additionalProperty = SPEC_PROPS
  .filter(({ key }) => robot[key] && robot[key].trim() && !robot[key].trim().startsWith('N/A'))
  .map(({ key, name: propName }) => ({
    '@type': 'PropertyValue',
    name: propName,
    value: robot[key].trim(),
  }));
if (additionalProperty.length > 0) jsonLd.additionalProperty = additionalProperty;

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE_URL}/` },
    { '@type': 'ListItem', position: 2, name: catLabel, item: `${SITE_URL}/?category=${robot.category}` },
    { '@type': 'ListItem', position: 3, name, item: url },
  ],
};

// Add offers if price is numeric
if (robot.price && !/not disclosed|on request|prototype|discontinued/i.test(robot.price)) {
  const priceMatch = robot.price.match(/([\d,.\s]+)\s*(USD|EUR)?/i);
  if (priceMatch) {
    const priceNum = parseFloat(priceMatch[1].replace(/[,\s]/g, ''));
    if (!isNaN(priceNum)) {
      jsonLd.offers = {
        '@type': 'Offer',
        availability: 'https://schema.org/InStock',
        priceCurrency: (priceMatch[2] || 'USD').toUpperCase(),
        price: priceNum,
      };
    }
  }
}
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLd).replace(/</g, '\\u003c')} />
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd).replace(/</g, '\\u003c')} />
