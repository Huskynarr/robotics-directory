---
import { translations } from '../data/translations.js';
import { CATEGORIES, USE_CASES } from '../data/categories.js';
const t = translations.en;

interface Props {
  manufacturers: string[];
}

const { manufacturers } = Astro.props;
---

<section class="relative z-10 -mt-5 pb-2" id="filtersSection" aria-label="Catalog filters">
  <div class="max-w-6xl mx-auto px-4">
    <div
      class="rounded-2xl border border-border bg-surface/95 p-3 md:p-4 shadow-[0_12px_40px_rgba(15,23,42,0.1)] backdrop-blur-xl"
    >
      <div class="grid lg:grid-cols-[minmax(0,1fr)_auto] gap-2.5">
        <div class="relative flex-1">
          <i
            class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-text-muted"
            aria-hidden="true"></i>
          <input
            type="search"
            id="searchInput"
            class="form-control h-12 w-full pl-11 pr-4 rounded-xl text-sm placeholder:text-text-muted"
            data-i18n-placeholder="search.placeholder"
            placeholder={t['search.placeholder']}
            autocomplete="off"
          />
        </div>

        <div class="grid grid-cols-[minmax(0,1fr)_auto] gap-2.5">
          <select
            id="sortFilter"
            class="form-control form-select h-12 min-w-0 lg:w-44 text-sm rounded-xl pl-3"
            aria-label="Sort"
          >
            <option value="recommended" data-i18n="filters.sort.recommended">Recommended</option>
            <option value="newest" data-i18n="filters.sort.newest">Newest</option>
            <option value="name" data-i18n="filters.sort.name">Name</option>
            <option value="manufacturer" data-i18n="filters.sort.manufacturer">Manufacturer</option>
            <option value="price" data-i18n="filters.sort.price">Price</option>
            <option value="price-desc" data-i18n="filters.sort.priceDesc">Price ↓</option>
            <option value="weight" data-i18n="spec.weight">Weight</option>
          </select>
          <button
            id="advancedToggle"
            class="filter-toggle h-12 shrink-0 inline-flex items-center justify-center gap-2 rounded-xl bg-primary px-4 text-sm font-bold text-white hover:bg-primary-dark transition-colors"
            aria-expanded="false"
            aria-controls="advancedFilters"
            aria-label={t['filters.advanced']}
            data-i18n-aria="filters.advanced"
          >
            <i class="fas fa-sliders" aria-hidden="true"></i>
            <span class="filter-toggle-label" data-i18n="filters.advanced">Filters</span>
          </button>
        </div>
      </div>

      <div
        class="flex md:hidden gap-2 overflow-x-auto pt-3 scrollbar-hide"
        id="mobileCategoryPills"
      >
        <button class="category-pill active shrink-0" data-category="all" data-i18n="nav.all"
          >All</button
        >
        {
          CATEGORIES.map((category) => (
            <button
              class="category-pill shrink-0"
              data-category={category.id}
              data-i18n={`nav.${category.id}`}
            >
              {t[`nav.${category.id}`]}
            </button>
          ))
        }
      </div>

      <div id="activeFilters" class="flex flex-wrap gap-2 pt-3 empty:hidden"></div>

      <div id="advancedFilters" class="hidden mt-4 pt-4 border-t border-border">
        <div class="grid md:grid-cols-[14rem_1fr] gap-4 mb-5">
          <label class="text-xs font-bold text-text-secondary uppercase tracking-wider">
            Manufacturer
            <select
              id="manufacturerFilter"
              class="form-control form-select mt-2 w-full text-sm rounded-lg px-3 py-2.5"
            >
              <option value="" data-i18n="filters.all">{t['filters.all']}</option>
              {
                manufacturers.map((manufacturer) => (
                  <option value={manufacturer}>{manufacturer}</option>
                ))
              }
            </select>
          </label>
          <fieldset>
            <legend class="text-xs font-bold text-text-secondary uppercase tracking-wider mb-2">
              Use case
            </legend>
            <div class="flex gap-2 overflow-x-auto scrollbar-hide" id="useCasePills">
              {
                USE_CASES.map((useCase) => (
                  <button
                    class="usecase-pill shrink-0 inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-full text-xs font-semibold border border-border bg-bg text-text-secondary hover:border-current transition-all"
                    data-usecase={useCase.id}
                    data-i18n={useCase.i18nKey}
                    style={`--uc-color: ${useCase.color}`}
                  >
                    <i class={`fas ${useCase.icon} text-[0.65rem]`} aria-hidden="true" />
                    <span>{t[useCase.i18nKey] || useCase.id}</span>
                  </button>
                ))
              }
            </div>
          </fieldset>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          <fieldset>
            <legend class="text-xs font-bold text-text-secondary uppercase tracking-wider mb-2">
              Price <span class="normal-case tracking-normal">(USD)</span>
            </legend>
            <div class="flex flex-wrap gap-2">
              <button class="price-pill" data-price="low" data-i18n="filters.price.low"
                >Under $5,000</button
              >
              <button class="price-pill" data-price="medium" data-i18n="filters.price.medium"
                >$5,000–$50,000</button
              >
              <button class="price-pill" data-price="high" data-i18n="filters.price.high"
                >Over $50,000</button
              >
              <button class="price-pill" data-price="request" data-i18n="filters.price.request"
                >On request</button
              >
            </div>
          </fieldset>

          <fieldset>
            <legend
              class="text-xs font-bold text-text-secondary uppercase tracking-wider mb-2"
              data-i18n="filter.size">Size</legend
            >
            <div class="flex flex-wrap gap-2">
              <button class="filter-pill" data-size="verysmall" data-i18n="filter.size.verySmall"
                >Very small</button
              >
              <button class="filter-pill" data-size="small" data-i18n="filter.size.small"
                >Small</button
              >
              <button class="filter-pill" data-size="medium" data-i18n="filter.size.medium"
                >Medium</button
              >
              <button class="filter-pill" data-size="large" data-i18n="filter.size.large"
                >Large</button
              >
            </div>
          </fieldset>

          <div class="grid grid-cols-2 gap-2">
            <label class="text-xs font-bold text-text-secondary uppercase tracking-wider">
              <span data-i18n="spec.weight">Weight</span>
              <select
                id="weightFilter"
                class="form-control form-select mt-2 w-full text-sm rounded-lg px-3 py-2.5"
              >
                <option value="" data-i18n="filters.all">All</option>
                <option value="light" data-i18n="filters.weight.light">Light</option>
                <option value="medium" data-i18n="filters.weight.medium">Medium</option>
                <option value="heavy" data-i18n="filters.weight.heavy">Heavy</option>
              </select>
            </label>
            <label class="text-xs font-bold text-text-secondary uppercase tracking-wider">
              <span data-i18n="spec.batteryLife">Battery</span>
              <select
                id="batteryFilter"
                class="form-control form-select mt-2 w-full text-sm rounded-lg px-3 py-2.5"
              >
                <option value="" data-i18n="filters.all">All</option>
                <option value="short" data-i18n="filters.battery.short">Short</option>
                <option value="medium" data-i18n="filters.battery.medium">Medium</option>
                <option value="long" data-i18n="filters.battery.long">Long</option>
              </select>
            </label>
          </div>

          <div class="grid grid-cols-2 gap-2">
            <label class="text-xs font-bold text-text-secondary uppercase tracking-wider">
              <span data-i18n="spec.ipRating">IP rating</span>
              <select
                id="ipRatingFilter"
                class="form-control form-select mt-2 w-full text-sm rounded-lg px-3 py-2.5"
              >
                <option value="" data-i18n="filters.all">All</option>
                <option value="any" data-i18n="filters.ip.any">Any rating</option>
              </select>
            </label>
            <label class="text-xs font-bold text-text-secondary uppercase tracking-wider">
              <span data-i18n="spec.video">Video</span>
              <select
                id="videoFilter"
                class="form-control form-select mt-2 w-full text-sm rounded-lg px-3 py-2.5"
              >
                <option value="" data-i18n="filters.all">All</option>
                <option value="yes" data-i18n="filters.video">Has video</option>
              </select>
            </label>
          </div>
        </div>
        <div class="flex justify-end mt-4">
          <button
            id="resetFilters"
            class="text-sm text-text-secondary hover:text-danger font-bold transition-colors"
            data-i18n="filters.reset">Reset filters</button
          >
        </div>
      </div>
    </div>
  </div>
</section>
