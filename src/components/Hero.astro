---
import { translations } from '../data/translations.js';
import { getAllRobots } from '../data/robots.js';
import { CATEGORIES } from '../data/categories.js';

const t = translations.en;
const { allRobots } = getAllRobots();
const stats = [
  { value: allRobots.length, key: 'hero.statRobots', label: 'Robots' },
  { value: CATEGORIES.length, key: 'hero.statCategories', label: 'Categories' },
  { value: Object.keys(translations).length, key: 'hero.statLanguages', label: 'Languages' },
];
---

<section class="relative overflow-hidden py-11 md:py-15 border-b border-white/10">
  <div class="absolute inset-0 bg-gradient-to-br from-slate-950 via-primary-dark to-cyan-900"></div>
  <div
    class="absolute inset-0 bg-[radial-gradient(circle_at_78%_20%,rgba(103,232,249,0.12),transparent_30%),radial-gradient(circle_at_16%_90%,rgba(129,140,248,0.16),transparent_34%)]"
  >
  </div>
  <div
    class="absolute inset-0 opacity-[0.04]"
    style="background-image: linear-gradient(rgba(255,255,255,0.35) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.35) 1px, transparent 1px); background-size: 56px 56px; mask-image: linear-gradient(to bottom, black, transparent);"
  >
  </div>

  <div class="relative max-w-7xl mx-auto px-4">
    <div class="max-w-4xl">
      <div
        class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.18em] text-white mb-3"
      >
        <i class="fas fa-robot" aria-hidden="true"></i>
        <span data-i18n="hero.badge">Robot Catalog</span>
      </div>
      <h1
        class="font-heading text-3xl md:text-5xl font-bold text-white mb-3 leading-[1.08] tracking-tight"
        data-i18n="hero.title"
      >
        {t['hero.title']}
      </h1>
      <p
        class="text-base md:text-lg text-white max-w-2xl mb-6 leading-relaxed"
        data-i18n="hero.subtitle"
      >
        {t['hero.subtitle']}
      </p>
      <div class="flex flex-col sm:flex-row sm:items-center gap-5 sm:gap-7">
        <a
          href="/finder/"
          class="inline-flex self-start items-center gap-2 px-5 py-3 rounded-xl bg-white text-primary-dark font-bold text-sm shadow-[0_10px_30px_rgba(0,0,0,0.24)] hover:-translate-y-0.5 hover:shadow-[0_14px_36px_rgba(0,0,0,0.3)] transition-all no-underline"
        >
          <i class="fas fa-wand-magic-sparkles" aria-hidden="true"></i>
          <span data-i18n="hero.finderCta">Find my robot</span>
        </a>
        <dl class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-white">
          {
            stats.map((stat) => (
              <div class="flex items-baseline gap-1.5">
                <dt class="order-2 font-medium" data-i18n={stat.key}>
                  {stat.label}
                </dt>
                <dd class="font-heading font-bold text-lg tabular-nums">{stat.value}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </div>
  </div>
</section>
