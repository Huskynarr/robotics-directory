---
import { translations } from '../data/translations.js';
import { getAllRobots } from '../data/robots.js';
import { CATEGORIES } from '../data/categories.js';

const t = translations.en;
const { allRobots } = getAllRobots();
const robotCount = allRobots.length;
const categoryCount = CATEGORIES.length;
const languageCount = Object.keys(translations).length;
---

<section class="relative overflow-hidden py-16 md:py-24 border-b border-white/10">
  <!-- Gradient background - catalog-specific warm blue -->
  <div
    class="absolute inset-0 bg-gradient-to-br from-slate-950 via-primary-dark to-accent opacity-[0.97]"
  >
  </div>
  <div
    class="absolute inset-0 bg-[radial-gradient(circle_at_72%_28%,rgba(103,232,249,0.24),transparent_32%),radial-gradient(circle_at_18%_80%,rgba(129,140,248,0.28),transparent_38%)]"
  >
  </div>
  <!-- Circuit grid overlay for tech feel -->
  <div
    class="absolute inset-0 opacity-[0.05]"
    style="background-image: linear-gradient(rgba(255,255,255,0.35) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.35) 1px, transparent 1px); background-size: 56px 56px; mask-image: linear-gradient(to bottom, black, transparent);"
  >
  </div>

  <div class="relative max-w-5xl mx-auto px-4 text-center">
    <!-- Page identifier badge -->
    <div
      class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold uppercase tracking-widest text-white/70 border border-white/15 mb-5 backdrop-blur-sm bg-white/5"
    >
      <i class="fas fa-robot"></i>
      <span data-i18n="hero.badge">Robot Catalog</span>
    </div>

    <h1
      class="font-heading text-4xl md:text-6xl font-bold text-white mb-5 leading-[1.08] tracking-tight"
      data-i18n="hero.title"
    >
      {t['hero.title']}
    </h1>
    <p
      class="text-base md:text-xl text-white/75 max-w-2xl mx-auto mb-8 leading-relaxed"
      data-i18n="hero.subtitle"
    >
      {t['hero.subtitle']}
    </p>

    <!-- Guided finder CTA -->
    <div class="mb-9">
      <a
        href="/finder/"
        class="inline-flex items-center gap-2 px-6 py-3.5 rounded-xl bg-white text-primary-dark font-semibold text-sm md:text-base shadow-[0_12px_40px_rgba(0,0,0,0.24)] hover:-translate-y-0.5 hover:shadow-[0_16px_48px_rgba(0,0,0,0.3)] transition-all no-underline"
      >
        <i class="fas fa-wand-magic-sparkles"></i>
        <span data-i18n="hero.finderCta">Find my robot</span>
      </a>
    </div>

    <!-- Stats strip -->
    <div class="flex items-center justify-center gap-6 md:gap-10 text-white/60 text-sm">
      <div class="flex items-center gap-2">
        <span class="font-heading font-bold text-xl md:text-2xl text-white tabular-nums"
          >{robotCount}</span
        >
        <span data-i18n="hero.statRobots">Robots</span>
      </div>
      <div class="w-px h-6 bg-white/20"></div>
      <div class="flex items-center gap-2">
        <span class="font-heading font-bold text-xl md:text-2xl text-white tabular-nums"
          >{categoryCount}</span
        >
        <span data-i18n="hero.statCategories">Categories</span>
      </div>
      <div class="w-px h-6 bg-white/20"></div>
      <div class="flex items-center gap-2">
        <i class="fas fa-globe text-white/40"></i>
        <span class="font-heading font-bold text-xl md:text-2xl text-white tabular-nums"
          >{languageCount}</span
        >
        <span data-i18n="hero.statLanguages">Languages</span>
      </div>
    </div>
  </div>
</section>
