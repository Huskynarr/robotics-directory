---
import { getAllRobots } from '../data/robots.js';
import { CATEGORIES } from '../data/categories.js';
import { SITE_URL, SITE_NAME, SITE_AUTHOR, GOOGLE_VERIFICATION } from '../config/site.js';
import { translations } from '../data/translations.js';

const { allRobots } = getAllRobots();
const supportedLanguages = Object.keys(translations);

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  jsonLd?: object;
  preloadImage?: string;
}

const {
  title = `${SITE_NAME} - Comprehensive Robot Database & Comparison Tool`,
  description = `Browse ${allRobots.length}+ robots across ${CATEGORIES.length} categories. Compare humanoids, robot dogs, household robots and more with specs, images and filters. Free open-source robot database.`,
  canonical = `${SITE_URL}/`,
  ogImage,
  jsonLd,
  preloadImage,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="robots"
      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
    />
    <meta name="author" content={SITE_AUTHOR} />
    <meta name="theme-color" content="#1e40af" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {preloadImage && <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />}
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage || `${SITE_URL}/images/logos/huskynarr.svg`} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:locale:alternate" content="de_DE" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage || `${SITE_URL}/images/logos/huskynarr.svg`} />
    {GOOGLE_VERIFICATION && <meta name="google-site-verification" content={GOOGLE_VERIFICATION} />}
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' https: data:; frame-src https://www.youtube.com https://www.youtube-nocookie.com; connect-src 'self'"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript
      ><link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap"
      /></noscript
    >
    <link
      rel="preload"
      as="style"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
      onload="this.onload=null;this.rel='stylesheet'"
      integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
        crossorigin="anonymous"
        referrerpolicy="no-referrer"
      />
    </noscript>
    {
      jsonLd && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(jsonLd).replace(/</g, '\\u003c')}
        />
      )
    }
    <script is:inline define:vars={{ supportedLanguages }}>
      // Inline appearance and language init to prevent theme/language flashes.
      (function () {
        var storedMode = null;
        var storedLanguage = null;
        try {
          storedMode = localStorage.getItem('darkMode');
          storedLanguage = localStorage.getItem('lang');
        } catch {
          /* localStorage unavailable */
        }
        var urlLanguage = new URLSearchParams(window.location.search).get('lang');
        var expectedLanguage = supportedLanguages.includes(urlLanguage) ? urlLanguage : null;
        if (!expectedLanguage && supportedLanguages.includes(storedLanguage)) {
          expectedLanguage = storedLanguage;
        }
        if (!expectedLanguage) {
          var browserLanguage = (navigator.language || 'en').toLowerCase().split('-')[0];
          expectedLanguage = supportedLanguages.includes(browserLanguage) ? browserLanguage : 'en';
        }
        if (expectedLanguage !== 'en') {
          document.documentElement.setAttribute('data-i18n-loading', '');
        }
        var systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (storedMode === 'true' || (storedMode === null && systemPrefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-bg text-text-base">
    <a href="#main" class="skip-to-content">Skip to content</a>
    <slot />
  </body>
</html>
